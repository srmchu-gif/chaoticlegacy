# Porta local da app (opcional, para LAN/debug)
APP_PUBLIC_PORT=25565

# Cloudflare Tunnel (recomendado quando 80/443 nao estao abertos)
CF_TUNNEL_TOKEN=cole-o-token-do-tunnel

DUCKDNS_SUBDOMAIN=seu-subdominio
DUCKDNS_DOMAIN=seu-subdominio.duckdns.org
DUCKDNS_TOKEN=coloque-seu-token
LETSENCRYPT_EMAIL=seu-email@dominio.com
TZ=America/Sao_Paulo
PUID=1000
PGID=1000

# Opcional (hardening)
SESSION_TTL_MS=604800000
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=25
ACTION_RATE_LIMIT_WINDOW_MS=10000
ACTION_RATE_LIMIT_MAX=40

# SMTP Gmail (obrigatorio para registro/verificacao por e-mail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-app-password
SMTP_FROM="Chaotic Legacy <seu-email@gmail.com>"
