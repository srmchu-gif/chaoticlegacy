{$DUCKDNS_DOMAIN} {
  encode zstd gzip

  header {
    X-Content-Type-Options "nosniff"
    X-Frame-Options "SAMEORIGIN"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "interest-cohort=()"
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    Content-Security-Policy "default-src 'self' https: data: blob:; img-src 'self' https: data: blob:; media-src 'self' https: data: blob:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline'; connect-src 'self' https: wss:; frame-src 'self' https://challenges.cloudflare.com; object-src 'none'; base-uri 'self'; form-action 'self';"
  }

  @sse path /api/multiplayer/events/*
  reverse_proxy @sse app:3000 {
    flush_interval -1
    transport http {
      dial_timeout 10s
      response_header_timeout 0
      read_timeout 0
      write_timeout 0
    }
  }

  reverse_proxy app:3000 {
    transport http {
      dial_timeout 10s
      response_header_timeout 60s
      read_timeout 0
      write_timeout 0
    }
  }
}
